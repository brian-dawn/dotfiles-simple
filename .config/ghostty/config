theme = dark: Rose Pine,light:Rose Pine Dawn
#theme = flexoki-dark
#theme = dark:Gruvbox Dark,light:Gruvbox Light
#theme = dark:Everforest Dark,light:Everforest Light

# Pane splitting keybindings (Ctrl+Shift prefix)
keybind = ctrl+shift+backslash=new_split:right
keybind = ctrl+shift+minus=new_split:down

# Pane navigation keybindings (Ctrl+Shift prefix)
keybind = ctrl+shift+h=goto_split:left
keybind = ctrl+shift+j=goto_split:down
keybind = ctrl+shift+k=goto_split:up
keybind = ctrl+shift+l=goto_split:right

# Pane management
keybind = ctrl+shift+x=close_surface
keybind = ctrl+shift+equal=equalize_splits

# Tab navigation
keybind = ctrl+shift+t=new_tab
keybind = ctrl+shift+r=prompt_tab_title

keybind = ctrl+shift+1=goto_tab:1
keybind = ctrl+shift+2=goto_tab:2
keybind = ctrl+shift+3=goto_tab:3
keybind = ctrl+shift+4=goto_tab:4
keybind = ctrl+shift+5=goto_tab:5
keybind = ctrl+shift+6=goto_tab:6
keybind = ctrl+shift+7=goto_tab:7
keybind = ctrl+shift+8=goto_tab:8
keybind = ctrl+shift+9=goto_tab:9

# Disable inactive pane dimming
# unfocused-split-opacity = 1.0

# Padding around pane splits
window-padding-x = 8
window-padding-y = 8
